# Human-readable reference only — not read by setup scripts, Wrangler, or builds.
# Real env files (gitignored): repo-root `.env.local` (local dev) and `.env.production` (deploy).
# Create them with `bun run setup` / `bun run setup:prod`, or edit by hand using this file as a checklist.

# ---------------------------------------------------------------------------
# Local dev — repo-root `.env.local`
# ---------------------------------------------------------------------------
# SESSION_SECRET — required for the web worker. `bun run setup` generates one, or set a strong secret (min 16 characters).

# Cloudflare — optional if you use `bunx wrangler login`. Use only for API-token auth in the file (e.g. CI).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# Optional: local Wrangler worker script names (`bun run setup` can set these).
# If unset, generate-wrangler uses built-in defaults (cf-*-dev). Prod names: `.env.production`.
# WEB_WORKER_NAME=
# EXAMPLE_DO_WORKER_NAME=
# COORDINATOR_DO_WORKER_NAME=
# PROCESSOR_DO_WORKER_NAME=
# Any new durable-objects/my-name → MY_NAME_WORKER_NAME (see packages/scripts/src/utils/generate-wrangler.ts)

# ---------------------------------------------------------------------------
# Production — repo-root `.env.production`
#
# `bun run setup:prod`. Required for `bun run deploy` / `deploy:execute`.
# Verify: `bun run check-prod-env`.
#
# Same keys as above where applicable; `generate-wrangler --mode=remote` merges deployment keys (routes + discovered `*_WORKER_NAME` from templates). See packages/scripts/src/utils/workspace-worker-catalog.ts
# ROUTES=
# ROUTES_ZONE_NAME=
