# Documentation template — not loaded by tooling. Use `bun run setup` (or `cp .env.example .env.local`)
# to create `.env.local`, then edit values there. See README "Quick Start".

# ---------------------------------------------------------------------------
# Local dev (copy into .env.local)
# ---------------------------------------------------------------------------
# SESSION_SECRET — any string for local dev; use a strong secret in production.
SESSION_SECRET=dev-only-replace-with-openssl-rand-base64-32

VALUE_FROM_CLOUDFLARE=Hello from local dev

# Cloudflare CLI / deploy — get from dashboard; not required for `bun run dev` in many flows,
# but set these before `wrangler deploy`, `bun run deploy`, or `bun run deploy:execute`.
CLOUDFLARE_API_TOKEN=replace_me_after_cp_to_env_local
CLOUDFLARE_ACCOUNT_ID=replace_me_after_cp_to_env_local

# ---------------------------------------------------------------------------
# Optional: local Wrangler worker script names (`bun run setup` can set these).
# If unset, generate-wrangler uses built-in defaults (cf-*-dev). Prod names: .env.production.
# WEB_WORKER_NAME=
# EXAMPLE_DO_WORKER_NAME=
# COORDINATOR_DO_WORKER_NAME=
# PROCESSOR_DO_WORKER_NAME=
# Any new durable-objects/my-name → MY_NAME_WORKER_NAME (see packages/scripts/src/utils/generate-wrangler.ts)

# ---------------------------------------------------------------------------
# Production wrangler only (`.env.production` — optional until you ship)
# generate-wrangler --mode=remote merges only DEPLOYMENT_KEYS; see packages/scripts/src/utils/generate-wrangler.ts
# ROUTES=
# ROUTES_ZONE_NAME=
