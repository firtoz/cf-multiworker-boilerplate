{
	"name": "{{ kebabCase name }}",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts"
	},
	"scripts": {
		"deploy": "alchemy deploy --app {{ kebabCase name }}",
		"destroy": "alchemy destroy --app {{ kebabCase name }}",
		"dev": "wrangler dev --config wrangler.jsonc --show-interactive-dev-session=false",
		"typegen:local": "node -e \"process.exit(0)\"",
		"typegen:prod": "node -e \"process.exit(0)\"",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"packageManager": "bun@1.3.0",
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260423.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
		"hono": "catalog:"
	}
}
