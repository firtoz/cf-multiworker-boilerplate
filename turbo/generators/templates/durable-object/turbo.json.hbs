{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["typegen:local"],
			"inputs": ["workers/**/*.ts", "alchemy.run.ts", "$TURBO_ROOT$/.env.local", "package.json"],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["workers/**/*.ts", "tsconfig.json", "tsconfig.cloudflare.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "tsconfig.json", "tsconfig.cloudflare.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"alchemy.run.ts",
				"tsconfig.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"alchemy.run.ts",
				"tsconfig.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:local": {
			"dependsOn": ["^typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"alchemy.run.ts",
				"$TURBO_ROOT$/.env.local",
				"package.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:prod": {
			"dependsOn": ["^typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"alchemy.run.ts",
				"$TURBO_ROOT$/.env.production",
				"package.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"deploy": {
			"dependsOn": ["typecheck:prod"],
			"cache": false,
			"outputs": []
		},
		"destroy": {
			"cache": false,
			"outputs": []
		}
	}
}
