{
	"name": "cf-web-app",
	"private": true,
	"type": "module",
	"scripts": {
		"generate-wrangler:local": "bun ../../packages/scripts/src/utils/generate-wrangler.ts --mode=local",
		"generate-wrangler:prod": "bun --env-file ../../.env.production ../../packages/scripts/src/utils/generate-wrangler.ts --mode=remote",
		"build:local": "WRANGLER_CONFIG_FILE=./wrangler-dev.jsonc bun --env-file ../../.env.local react-router build --mode production",
		"build:prod": "WRANGLER_CONFIG_FILE=./wrangler-prod.jsonc bun --env-file ../../.env.production react-router build --mode production",
		"build:dev": "react-router build --mode development",
		"typegen:local": "bun run cf-typegen:local && bun run rr-typegen",
		"typegen:prod": "bun run cf-typegen:prod && bun run rr-typegen",
		"cf-typegen:local": "bun ../../packages/scripts/src/cf-typegen.ts $(pwd) --apps-web-config=wrangler-dev.jsonc --env-file ../../.env.local",
		"cf-typegen:prod": "bun ../../packages/scripts/src/cf-typegen.ts $(pwd) --apps-web-config=wrangler-prod.jsonc --env-file ../../.env.production",
		"rr-typegen": "react-router typegen",
		"deploy": "node -e \"process.exit(0)\"",
		"deploy:execute": "bunx wrangler deploy -c build/server/wrangler.json",
		"dev": "NODE_OPTIONS=\"--no-network-family-autoselection${NODE_OPTIONS:+ $NODE_OPTIONS}\" bun --env-file ../../.env.local react-router dev",
		"preview": "bun run build:local && vite preview",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.cloudflare.json && tsgo --noEmit -p ./tsconfig.node.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.cloudflare.json && tsgo --noEmit -p ./tsconfig.node.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
		"@firtoz/maybe-error": "^1.6.1",
		"@firtoz/router-toolkit": "^8.0.1",
		"clsx": "^2.1.1",
		"example-do": "workspace:*",
		"hono": "catalog:",
		"isbot": "^5.1.39",
		"jotai": "^2.19.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router": "^7.14.1",
		"tailwind-merge": "^3.5.0",
		"uuid": "catalog:",
		"zod": "catalog:",
		"zod-form-data": "^3.0.1",
		"zod-validation-error": "^5.0.0"
	},
	"devDependencies": {
		"coordinator-do": "workspace:*",
		"processor-do": "workspace:*",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@cloudflare/vite-plugin": "^1.32.3",
		"@react-router/dev": "^7.14.1",
		"@tailwindcss/vite": "^4.2.2",
		"@types/json-diff": "^1.0.3",
		"@types/node": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"image-size": "^2.0.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"source-map-explorer": "^2.5.3",
		"tailwindcss": "^4.2.2",
		"typescript": "catalog:",
		"vite": "^8.0.8",
		"vite-imagetools": "^10.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"wrangler": "catalog:"
	},
	"packageManager": "bun@1.3.0"
}
