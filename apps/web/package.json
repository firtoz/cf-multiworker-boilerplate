{
	"name": "cf-starter-web",
	"private": true,
	"type": "module",
	"exports": {
		"./alchemy": "./alchemy.run.ts"
	},
	"scripts": {
		"build:local": "bun --env-file ../../.env.local react-router build --mode production",
		"build:prod": "bun --env-file ../../.env.production react-router build --mode production",
		"build:dev": "react-router build --mode development",
		"typegen:local": "bun run rr-typegen",
		"typegen:prod": "bun run rr-typegen",
		"rr-typegen": "react-router typegen",
		"deploy": "alchemy deploy --app web",
		"destroy": "alchemy destroy --app web",
		"dev": "NODE_OPTIONS=\"--no-network-family-autoselection${NODE_OPTIONS:+ $NODE_OPTIONS}\" alchemy dev --app web",
		"preview": "bun run build:local && vite preview",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.cloudflare.json && tsgo --noEmit -p ./tsconfig.node.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.cloudflare.json && tsgo --noEmit -p ./tsconfig.node.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write ."
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
		"@firtoz/maybe-error": "^1.6.1",
		"@firtoz/router-toolkit": "^9.0.1",
		"@firtoz/socka": "^3.0.1",
		"cf-starter-chat-contract": "workspace:*",
		"cf-starter-db": "workspace:*",
		"clsx": "^2.1.1",
		"chatroom-do": "workspace:*",
		"ping-do": "workspace:*",
		"hono": "catalog:",
		"isbot": "^5.1.39",
		"jotai": "^2.19.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-router": "^7.14.2",
		"tailwind-merge": "^3.5.0",
		"uuid": "catalog:",
		"zod": "catalog:",
		"zod-form-data": "^3.0.1",
		"zod-validation-error": "^5.0.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260423.1",
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@react-router/dev": "^7.14.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/json-diff": "^1.0.3",
		"@types/node": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"alchemy": "^0.93.0",
		"image-size": "^2.0.2",
		"other-worker": "workspace:*",
		"rollup-plugin-visualizer": "^7.0.1",
		"source-map-explorer": "^2.5.3",
		"tailwindcss": "^4.2.4",
		"typescript": "catalog:",
		"vite": "^8.0.10",
		"vite-imagetools": "^10.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"wrangler": "catalog:"
	},
	"packageManager": "bun@1.3.0"
}
