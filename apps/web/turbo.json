{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"generate-wrangler:local": {
			"dependsOn": ["scripts#build:local"],
			"inputs": ["wrangler.jsonc.hbs", "$TURBO_ROOT$/.env.local"],
			"outputs": ["wrangler-dev.jsonc"],
			"env": []
		},
		"generate-wrangler:prod": {
			"inputs": ["wrangler.jsonc.hbs", "$TURBO_ROOT$/.env.production"],
			"outputs": ["wrangler-prod.jsonc"],
			"env": [
				"ROUTES",
				"ROUTES_ZONE_NAME",
				"WEB_WORKER_NAME",
				"EXAMPLE_DO_WORKER_NAME",
				"COORDINATOR_DO_WORKER_NAME",
				"PROCESSOR_DO_WORKER_NAME",
				"SESSION_SECRET"
			]
		},
		"typegen:local": {
			"dependsOn": ["^generate-wrangler:local", "generate-wrangler:local"],
			"inputs": [
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"wrangler.jsonc.hbs",
				"wrangler-dev.jsonc",
				"$TURBO_ROOT$/.env.local",
				"package.json",
				"../../packages/scripts/src/**/*.ts"
			],
			"outputs": ["worker-configuration.d.ts"]
		},
		"typegen:prod": {
			"dependsOn": ["^generate-wrangler:prod", "generate-wrangler:prod"],
			"inputs": [
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"wrangler.jsonc.hbs",
				"wrangler-prod.jsonc",
				"$TURBO_ROOT$/.env.production",
				"package.json",
				"../../packages/scripts/src/**/*.ts"
			],
			"outputs": ["worker-configuration.d.ts"]
		},
		"rr-typegen": {
			"inputs": [
				"app/routes.ts",
				"app/routes/**/*.ts",
				"app/routes/**/*.tsx",
				"react-router.config.ts",
				"package.json"
			],
			"outputs": [".react-router/**"]
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"biome.json",
				"vite.config.ts",
				"react-router.config.ts",
				"wrangler-dev.jsonc",
				"wrangler-prod.jsonc",
				"wrangler.jsonc.hbs"
			],
			"outputs": []
		},
		"lint:format": {
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"biome.json",
				"vite.config.ts",
				"react-router.config.ts",
				"wrangler-dev.jsonc",
				"wrangler-prod.jsonc",
				"wrangler.jsonc.hbs"
			],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"tsconfig.json",
				"tsconfig.node.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"tsconfig.json",
				"tsconfig.node.json",
				"tsconfig.cloudflare.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"dev": {
			"dependsOn": ["^typegen:local", "typegen:local"],
			"persistent": true,
			"cache": false
		},
		"build:local": {
			"dependsOn": ["typecheck:local"],
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"vite.config.ts",
				"react-router.config.ts",
				"wrangler-dev.jsonc",
				"wrangler.jsonc.hbs",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"node_modules/.cache/imagetools"
			],
			"outputs": ["build/**/*"]
		},
		"build:prod": {
			"dependsOn": ["typecheck:prod"],
			"inputs": [
				"app/**/*.ts",
				"app/**/*.tsx",
				"workers/**/*.ts",
				"workers/**/*.tsx",
				"vite.config.ts",
				"react-router.config.ts",
				"wrangler-prod.jsonc",
				"wrangler.jsonc.hbs",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"node_modules/.cache/imagetools"
			],
			"outputs": ["build/**/*"]
		},
		"deploy": {
			"dependsOn": ["scripts#wrangler:dry-run:prod"],
			"outputs": []
		},
		"deploy:execute": {
			"dependsOn": ["scripts#sync-secrets:prod", "scripts#pre-deploy", "build:prod", "^deploy"],
			"inputs": ["build/**/*", "wrangler-prod.jsonc"],
			"outputs": [],
			"env": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
		}
	}
}
