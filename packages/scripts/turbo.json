{
	"extends": ["//"],
	"tasks": {
		"build": {
			"inputs": ["src/**/*.ts", "package.json"],
			"outputs": []
		},
		"build:local": {
			"inputs": ["src/**/*.ts", "package.json"],
			"outputs": []
		},
		"typecheck:local": {
			"inputs": ["src/**/*.ts", "tsconfig.json"],
			"outputs": []
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["src/**/*.ts", "tsconfig.json", "$TURBO_ROOT$/biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["src/**/*.ts", "tsconfig.json", "$TURBO_ROOT$/biome.json"],
			"outputs": []
		},
		"wrangler:dry-run:prod": {
			"dependsOn": ["cf-starter-web#build:prod"],
			"env": [
				"CLOUDFLARE_API_TOKEN",
				"CLOUDFLARE_ACCOUNT_ID",
				"ROUTES",
				"ROUTES_ZONE_NAME",
				"WEB_WORKER_NAME",
				"EXAMPLE_DO_WORKER_NAME",
				"COORDINATOR_DO_WORKER_NAME",
				"PROCESSOR_DO_WORKER_NAME"
			],
			"inputs": [
				"src/wrangler-dry-run-prod.ts",
				"$TURBO_ROOT$/apps/web/wrangler.jsonc.hbs",
				"$TURBO_ROOT$/durable-objects/**/wrangler.jsonc.hbs",
				"$TURBO_ROOT$/durable-objects/**/wrangler-prod.jsonc",
				"$TURBO_ROOT$/apps/web/build/server/wrangler.json"
			],
			"outputs": []
		},
		"sync-secrets:prod": {
			"dependsOn": [
				"cf-starter-web#generate-wrangler:prod",
				"example-do#generate-wrangler:prod",
				"coordinator-do#generate-wrangler:prod",
				"processor-do#generate-wrangler:prod"
			],
			"inputs": [
				"src/sync-wrangler-secrets.ts",
				"src/load-env-production.ts",
				"$TURBO_ROOT$/.env.production",
				"$TURBO_ROOT$/apps/**/wrangler-prod.jsonc",
				"$TURBO_ROOT$/durable-objects/**/wrangler-prod.jsonc"
			],
			"outputs": [],
			"env": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
		},
		"pre-deploy": {
			"dependsOn": ["scripts#sync-secrets:prod", "cf-starter-web#generate-wrangler:local"],
			"inputs": [
				"src/pre-deploy.ts",
				"src/load-env-production.ts",
				"$TURBO_ROOT$/**/wrangler-dev.jsonc",
				"$TURBO_ROOT$/**/wrangler-prod.jsonc",
				"$TURBO_ROOT$/**/wrangler.jsonc",
				"$TURBO_ROOT$/apps/web/wrangler.jsonc.hbs",
				"$TURBO_ROOT$/durable-objects/**/wrangler.jsonc.hbs",
				"$TURBO_ROOT$/.env.production"
			],
			"outputs": []
		}
	}
}
