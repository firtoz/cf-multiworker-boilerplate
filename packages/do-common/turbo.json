{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"inputs": ["*.ts", "tsconfig.json", "package.json", "$TURBO_ROOT$/tsconfig.base.json"],
			"outputs": []
		},
		"typecheck:prod": {
			"inputs": ["*.ts", "tsconfig.json", "package.json", "$TURBO_ROOT$/tsconfig.base.json"],
			"outputs": []
		}
	}
}
