{
	"name": "cf-multiworker-boilerplate",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"durable-objects/*"
		],
		"catalog": {
			"@typescript/native-preview": "^7.0.0-dev.20260418.1",
			"@biomejs/biome": "^2.4.12",
			"@firtoz/hono-fetcher": "^2.7.0",
			"@hono/zod-validator": "^0.7.6",
			"@types/node": "^25.6.0",
			"hono": "^4.12.14",
			"typescript": "^6.0.3",
			"uuid": "^13.0.0",
			"wrangler": "^4.83.0",
			"zod": "^4.3.6",
			"dotenv": "^17.4.0"
		}
	},
	"scripts": {
		"setup": "bun ./packages/scripts/src/bootstrap-env.ts",
		"setup:prod": "bun ./packages/scripts/src/bootstrap-env-prod.ts",
		"build": "turbo run build:local",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"lint:format": "turbo lint:format",
		"typecheck": "turbo run typecheck:local",
		"typecheck:local": "turbo run typecheck:local",
		"typecheck:root": "bunx tsc --noEmit -p .",
		"typecheck:prod": "turbo run typecheck:prod",
		"typegen": "turbo run typegen:local",
		"typegen:local": "turbo run typegen:local",
		"typegen:prod": "turbo run typegen:prod",
		"check-prod-env": "bun ./packages/scripts/src/check-prod-deploy-prereqs.ts",
		"deploy": "bun ./packages/scripts/src/check-prod-deploy-prereqs.ts && bun --env-file ./.env.production turbo run deploy --filter=cf-web-app",
		"deploy:execute": "bun ./packages/scripts/src/check-prod-deploy-prereqs.ts && bun --env-file ./.env.production turbo run deploy:execute --filter=cf-web-app",
		"outdated": "bun outdated --recursive",
		"update:interactive": "bun update --latest --ir",
		"clean": "turbo clean && rm -rf node_modules **/node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@turbo/gen": "^2.9.6",
		"@types/bun": "^1.3.12",
		"jsonc-parser": "^3.3.1",
		"turbo": "^2.9.6"
	},
	"packageManager": "bun@1.3.0",
	"dependencies": {
		"@firtoz/worker-helper": "^1.6.1",
		"uuid": "^13.0.0"
	}
}
