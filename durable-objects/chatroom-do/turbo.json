{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"dev": {
			"dependsOn": ["scripts#dev:preflight", "typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"wrangler.jsonc",
				"$TURBO_ROOT$/.env.local",
				"package.json"
			],
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["workers/**/*.ts", "src/**/*.ts", "wrangler.jsonc", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "src/**/*.ts", "wrangler.jsonc", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"drizzle/migrations.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"drizzle/migrations.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:local": {
			"dependsOn": ["^typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"$TURBO_ROOT$/.env.local",
				"package.json",
				"tsconfig.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"typegen:prod": {
			"dependsOn": ["^typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"src/**/*.ts",
				"$TURBO_ROOT$/.env.production",
				"package.json",
				"tsconfig.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"deploy": {
			"dependsOn": ["typecheck:prod", "cf-starter-chat-contract#typecheck:prod"],
			"cache": true,
			"inputs": [
				"alchemy.run.ts",
				"wrangler.jsonc",
				"workers/**/*.ts",
				"src/**/*.ts",
				"drizzle/**",
				"drizzle.config.ts",
				"package.json",
				"tsconfig.json",
				"env.d.ts"
			],
			"outputs": []
		},
		"destroy": {
			"cache": false,
			"outputs": []
		}
	}
}
