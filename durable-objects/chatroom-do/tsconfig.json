{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "ES2022",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2022"],
		"types": ["@cloudflare/workers-types/2023-07-01"],
		"resolveJsonModule": true,
		"noEmit": true
	},
	"include": [
		"workers/**/*.ts",
		"src/**/*.ts",
		"drizzle/**/*.ts",
		"drizzle.config.ts",
		"alchemy.run.ts",
		"env.d.ts"
	]
}
