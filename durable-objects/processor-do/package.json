{
	"name": "processor-do",
	"private": true,
	"type": "module",
	"scripts": {
		"generate-wrangler:local": "bun ../../packages/scripts/src/utils/generate-wrangler.ts --mode=local",
		"generate-wrangler:prod": "bun --env-file ../../.env.production ../../packages/scripts/src/utils/generate-wrangler.ts --mode=remote",
		"typegen:local": "bun run cf-typegen:local",
		"typegen:prod": "bun run cf-typegen:prod",
		"cf-typegen:local": "bun ../../packages/scripts/src/cf-typegen.ts $(pwd) --apps-web-config=wrangler-dev.jsonc --env-file ../../.env.local",
		"cf-typegen:prod": "bun ../../packages/scripts/src/cf-typegen.ts $(pwd) --apps-web-config=wrangler-prod.jsonc --env-file ../../.env.production",
		"typecheck:local": "tsgo --noEmit -p ./tsconfig.json",
		"typecheck:prod": "tsgo --noEmit -p ./tsconfig.json",
		"lint": "biome check --write .",
		"lint:format": "biome format --write .",
		"deploy": "bun ../../packages/scripts/src/deploy-cyclic-cross-worker.ts"
	},
	"packageManager": "bun@1.3.0",
	"devDependencies": {
		"@typescript/native-preview": "catalog:",
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	},
	"dependencies": {
		"@firtoz/hono-fetcher": "catalog:",
		"@hono/zod-validator": "catalog:",
		"do-common": "workspace:*",
		"hono": "catalog:",
		"zod": "catalog:"
	}
}
