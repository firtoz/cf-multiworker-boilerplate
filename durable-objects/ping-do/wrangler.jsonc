{
	"name": "cf-starter-ping-do",
	"main": "workers/app.ts",
	"compatibility_date": "2026-03-10",
	"compatibility_flags": ["nodejs_compat"],
	"dev": {
		"port": 1338,
		"inspector_port": 9238
	},
	"durable_objects": {
		"bindings": [{ "name": "PingDo", "class_name": "PingDo" }]
	},
	"migrations": [{ "tag": "v1", "new_classes": ["PingDo"] }],
	"services": [
		{
			"binding": "OTHER",
			"service": "cf-starter-other-worker"
		}
	]
}
