{
	"$schema": "../../node_modules/turbo/schema.json",
	"extends": ["//"],
	"tasks": {
		"generate-wrangler:local": {
			"dependsOn": ["scripts#build:local"],
			"inputs": ["wrangler.jsonc.hbs", "$TURBO_ROOT$/.env.local"],
			"outputs": ["wrangler-dev.jsonc"],
			"env": []
		},
		"generate-wrangler:prod": {
			"inputs": ["wrangler.jsonc.hbs", "$TURBO_ROOT$/.env.production"],
			"outputs": ["wrangler-prod.jsonc"],
			"env": [
				"ROUTES",
				"ROUTES_ZONE_NAME",
				"COORDINATOR_DO_WORKER_NAME",
				"PROCESSOR_DO_WORKER_NAME"
			]
		},
		"lint": {
			"dependsOn": ["typecheck:local"],
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"lint:format": {
			"inputs": ["workers/**/*.ts", "tsconfig.json", "biome.json"],
			"outputs": []
		},
		"typecheck:local": {
			"dependsOn": ["typegen:local"],
			"inputs": [
				"workers/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typecheck:prod": {
			"dependsOn": ["typegen:prod"],
			"inputs": [
				"workers/**/*.ts",
				"tsconfig.json",
				"package.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			],
			"outputs": []
		},
		"typegen:local": {
			"dependsOn": [
				"generate-wrangler:local",
				"cf-starter-web#generate-wrangler:local",
				"example-do#generate-wrangler:local",
				"processor-do#generate-wrangler:local"
			],
			"inputs": [
				"wrangler.jsonc.hbs",
				"wrangler-dev.jsonc",
				"workers/**/*.ts",
				"$TURBO_ROOT$/.env.local",
				"package.json",
				"../../packages/scripts/src/**/*.ts"
			],
			"outputs": ["worker-configuration.d.ts"]
		},
		"typegen:prod": {
			"dependsOn": [
				"generate-wrangler:prod",
				"cf-starter-web#generate-wrangler:prod",
				"example-do#generate-wrangler:prod",
				"processor-do#generate-wrangler:prod"
			],
			"inputs": [
				"wrangler.jsonc.hbs",
				"wrangler-prod.jsonc",
				"workers/**/*.ts",
				"$TURBO_ROOT$/.env.production",
				"package.json",
				"../../packages/scripts/src/**/*.ts"
			],
			"outputs": ["worker-configuration.d.ts"]
		},
		"deploy": {
			"dependsOn": [
				"scripts#sync-secrets:prod",
				"scripts#pre-deploy",
				"typecheck:prod",
				"processor-do#deploy"
			],
			"inputs": ["workers/**/*.ts", "wrangler-prod.jsonc", "wrangler.jsonc.hbs"],
			"outputs": [],
			"env": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
		}
	}
}
