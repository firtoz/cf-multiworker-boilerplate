{
	"$schema": "./node_modules/turbo/schema.json",
	"globalDependencies": [
		".env",
		".env.local",
		".env.production",
		"tsconfig.base.json"
	],
	"ui": "tui",
	"tasks": {
		"build": {
			"outputLogs": "new-only"
		},
		"build:local": {
			"outputLogs": "new-only"
		},
		"build:prod": {
			"outputLogs": "new-only"
		},
		"typecheck": {
			"outputLogs": "new-only"
		},
		"typecheck:local": {
			"outputLogs": "new-only"
		},
		"typecheck:prod": {
			"outputLogs": "new-only"
		},
		"typegen": {
			"outputLogs": "new-only"
		},
		"typegen:local": {
			"outputLogs": "new-only"
		},
		"typegen:prod": {
			"outputLogs": "new-only"
		},
		"cf-typegen": {
			"outputLogs": "new-only"
		},
		"cf-typegen:local": {
			"outputLogs": "new-only"
		},
		"cf-typegen:prod": {
			"outputLogs": "new-only"
		},
		"generate-wrangler:local": {
			"outputLogs": "new-only"
		},
		"generate-wrangler:prod": {
			"outputLogs": "new-only"
		},
		"rr-typegen": {
			"outputLogs": "new-only"
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"outputLogs": "new-only"
		},
		"lint": {
			"outputLogs": "new-only"
		},
		"pre-deploy": {
			"outputLogs": "new-only"
		},
		"wrangler:dry-run:prod": {
			"outputLogs": "new-only"
		},
		"deploy": {
			"outputLogs": "new-only"
		},
		"deploy:execute": {
			"outputLogs": "new-only"
		},
		"clean": {
			"cache": false
		}
	},
	"globalEnv": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID", "SESSION_SECRET", "CI"]
}
