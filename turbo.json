{
	"$schema": "./node_modules/turbo/schema.json",
	"globalDependencies": [".env.local", ".env.production", "tsconfig.base.json"],
	"ui": "tui",
	"tasks": {
		"build": {
			"outputLogs": "new-only"
		},
		"build:local": {
			"outputLogs": "new-only"
		},
		"build:prod": {
			"outputLogs": "new-only"
		},
		"typecheck": {
			"outputLogs": "new-only"
		},
		"typecheck:local": {
			"outputLogs": "new-only"
		},
		"typecheck:prod": {
			"outputLogs": "new-only"
		},
		"typegen": {
			"outputLogs": "new-only"
		},
		"typegen:local": {
			"outputLogs": "new-only"
		},
		"typegen:prod": {
			"outputLogs": "new-only"
		},
		"rr-typegen": {
			"outputLogs": "new-only"
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"outputLogs": "new-only"
		},
		"deploy": {
			"dependsOn": ["^deploy"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"destroy": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"chatroom-do#destroy": {
			"dependsOn": ["cf-starter-web#destroy"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"ping-do#destroy": {
			"dependsOn": ["cf-starter-web#destroy"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"other-worker#destroy": {
			"dependsOn": ["cf-starter-web#destroy"],
			"cache": false,
			"outputLogs": "new-only"
		},
		"lint": {
			"outputLogs": "new-only"
		},
		"lint:format": {
			"outputLogs": "new-only"
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"outputLogs": "new-only"
		},
		"d1:migrate:local": {
			"outputLogs": "new-only"
		},
		"d1:migrate:remote": {
			"outputLogs": "new-only"
		}
	},
	"globalEnv": [
		"CLOUDFLARE_API_TOKEN",
		"CLOUDFLARE_ACCOUNT_ID",
		"SESSION_SECRET",
		"CI",
		"ALCHEMY_PASSWORD",
		"STAGE"
	]
}
